      "source": [
        "from transformers import pipeline\n",
        "import gradio as gr\n",
        "\n",
        "# Load pretrained BERT fill-mask pipeline\n",
        "fill = pipeline(\"fill-mask\", model=\"bert-base-uncased\")\n",
        "\n",
        "def predict_mask(sentence):\n",
        "    try:\n",
        "        preds = fill(sentence)\n",
        "        results = []\n",
